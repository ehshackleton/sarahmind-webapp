# Copiar a .env.production en la VM y reemplazar los valores de ejemplo.
#
# Prerrequisitos:
# - La VM debe tener Docker, Docker Compose y Traefik activos.
# - Debe existir la red externa "proxy": docker network create proxy
# - El DNS del dominio publico debe apuntar a la IP de la VM.
#
# Secretos:
# - SECRET_KEY_BASE se genera con: bin/rails secret

POSTGRES_USER=sarahmind
POSTGRES_PASSWORD=cambiar_password_seguro

DATABASE_HOST=db
DATABASE_USER=sarahmind
DATABASE_PASSWORD=cambiar_password_seguro
DATABASE_NAME=sarahmind_production

SECRET_KEY_BASE=reemplazar_con_bin_rails_secret

APP_HOST=sarahmind.cl
APP_URL_PROTOCOL=https
TRAEFIK_HOST_RULE=Host(`sarahmind.cl`)

RAILS_LOG_LEVEL=info
