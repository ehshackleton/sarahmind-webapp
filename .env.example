# Copiar a .env y ajustar (no commitear .env).
# Desarrollo local sin Docker: DATABASE_HOST=localhost

DATABASE_HOST=localhost
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=sarahmind_development
DATABASE_TEST_NAME=sarahmind_test

# Contraseña para usuarios de db/seeds.rb (solo desarrollo; usa una fuerte en staging/producción)
# SEED_USER_PASSWORD=Cambiala123!

# Hilos del pool de Active Record (opcional)
# RAILS_MAX_THREADS=5

# Google Calendar (opcional): cuenta de servicio con acceso al calendario indicado.
# Sin estas variables, la sincronización se omite sin error.
# GOOGLE_CALENDAR_CREDENTIALS_PATH=/ruta/al/service-account.json
# GOOGLE_CALENDAR_CALENDAR_ID=calendario@group.calendar.google.com

# Producción: secretos reales vía plataforma de despliegue o credenciales cifradas
# APP_DATABASE_PASSWORD=
# RAILS_MASTER_KEY=
# APP_HOST=sarahmind.cl
# APP_URL_PROTOCOL=https
