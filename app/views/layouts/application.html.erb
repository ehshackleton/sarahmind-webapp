<!DOCTYPE html>
<html lang="es" class="h-full">
  <head>
    <title><%= content_for(:title) || "SarahMind" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&display=swap" rel="stylesheet">

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="flex min-h-full flex-col bg-sarah-bg text-sarah-ink antialiased">
    <a href="#contenido-principal" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-white focus:px-3 focus:py-2 focus:shadow">
      Ir al contenido principal
    </a>

    <header class="border-b border-sarah-border/80 bg-white/90 backdrop-blur">
      <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-4 md:px-6">
        <%= link_to root_path, class: "group flex min-w-0 items-center gap-2" do %>
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-sarah-calm/15 text-lg font-semibold text-sarah-calm" aria-hidden="true">S</span>
          <span class="font-serif text-xl font-semibold tracking-tight text-sarah-ink group-hover:text-sarah-calm-deep">SarahMind</span>
        <% end %>

        <details class="public-mobile-nav relative md:hidden">
          <summary class="flex cursor-pointer items-center gap-1.5 rounded-full border border-sarah-border bg-white px-3 py-2 text-sm font-medium text-sarah-ink shadow-sm" aria-label="Menú de navegación">
            <span>Menú</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-sarah-muted transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="absolute right-0 z-50 mt-2 max-h-[min(32rem,80vh)] w-[min(100vw-2rem,20rem)] overflow-y-auto rounded-2xl border border-sarah-border bg-white py-3 shadow-xl">
            <nav aria-label="Principal (móvil)" class="flex flex-col gap-0.5 px-2">
              <%= render "layouts/public_nav_links", stacked: true %>
            </nav>
          </div>
        </details>

        <nav aria-label="Principal" class="hidden items-center gap-5 text-sm font-medium text-sarah-muted md:flex">
          <%= render "layouts/public_nav_links", stacked: false %>
        </nav>
      </div>
    </header>

    <% if portal_workspace_nav? %>
      <%= render "portal/workspace_nav" %>
    <% end %>

    <% if notice.present? || alert.present? %>
      <div class="mx-auto max-w-5xl px-4 pt-6 md:px-6" role="status">
        <% if notice.present? %>
          <p class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-900"><%= notice %></p>
        <% end %>
        <% if alert.present? %>
          <p class="mt-2 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-900"><%= alert %></p>
        <% end %>
      </div>
    <% end %>

    <main id="contenido-principal" class="flex-1">
      <div class="<%= main_content_wrapper_classes %>">
        <%= yield %>
      </div>
    </main>

    <footer class="mt-auto border-t border-sarah-border/80 bg-white/80 py-8 text-sm text-sarah-muted">
      <div class="mx-auto flex max-w-5xl flex-col gap-4 px-4 md:flex-row md:items-center md:justify-between md:px-6">
        <p class="max-w-xl leading-relaxed">
          SarahMind acompaña la práctica clínica con herramientas sobrias, confidenciales y centradas en las personas.
        </p>
        <p class="text-xs text-sarah-muted/80">
          &copy; <%= Time.current.year %> SarahMind
        </p>
      </div>
    </footer>
  </body>
</html>
