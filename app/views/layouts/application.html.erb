<!DOCTYPE html>
<html lang="es" class="h-full">
  <head>
    <title><%= content_for(:title) || "SarahMind" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="flex min-h-full flex-col bg-sarah-bg text-sarah-ink antialiased">
    <a href="#contenido-principal" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-white focus:px-3 focus:py-2 focus:shadow">
      Ir al contenido principal
    </a>

    <header class="border-b border-sarah-border/80 bg-white/90 backdrop-blur">
      <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-4 md:px-6">
        <%= link_to root_path, class: "group flex items-center gap-2" do %>
          <span class="flex h-9 w-9 items-center justify-center rounded-full bg-sarah-calm/15 text-lg font-semibold text-sarah-calm" aria-hidden="true">S</span>
          <span class="font-serif text-xl font-semibold tracking-tight text-sarah-ink group-hover:text-sarah-calm">SarahMind</span>
        <% end %>
        <nav aria-label="Principal" class="hidden items-center gap-6 text-sm font-medium text-sarah-muted md:flex">
          <%= link_to "Inicio", root_path, class: "hover:text-sarah-ink" %>
          <%= link_to "Quiénes somos", "#", class: "hover:text-sarah-ink" %>
          <%= link_to "Cursos", "#", class: "hover:text-sarah-ink" %>
          <%= link_to "Contacto", "#", class: "hover:text-sarah-ink" %>
          <%= link_to "Portal", "#", class: "rounded-full bg-sarah-sand px-3 py-1.5 text-sarah-ink hover:bg-sarah-accent/20" %>
        </nav>
      </div>
    </header>

    <main id="contenido-principal" class="flex-1">
      <div class="mx-auto max-w-5xl px-4 py-10 md:px-6 md:py-14">
        <%= yield %>
      </div>
    </main>

    <footer class="mt-auto border-t border-sarah-border/80 bg-white/80 py-8 text-sm text-sarah-muted">
      <div class="mx-auto flex max-w-5xl flex-col gap-4 px-4 md:flex-row md:items-center md:justify-between md:px-6">
        <p class="max-w-xl leading-relaxed">
          Plataforma en construcción. Priorizamos privacidad, claridad y un tono cálido y profesional.
        </p>
        <p class="text-xs text-sarah-muted/80">
          &copy; <%= Time.current.year %> SarahMind
        </p>
      </div>
    </footer>
  </body>
</html>
