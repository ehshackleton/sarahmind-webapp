<% content_for :title, "Guía de auditoría y retención — Portal" %>

<section class="rounded-2xl border border-sarah-border bg-white/90 p-8 shadow-sm">
  <div class="flex flex-wrap items-start justify-between gap-4 border-b border-sarah-border/80 pb-4">
    <div>
      <h1 class="font-serif text-2xl font-semibold text-sarah-ink">Guía de auditoría y retención</h1>
      <p class="mt-2 text-sm text-sarah-muted">
        Documento operativo del repositorio (<code class="rounded bg-sarah-surface px-1 text-xs">docs/audit-and-data-retention.md</code>).
        Completa con la política legal e institucional de tu organización.
      </p>
    </div>
    <%= link_to "Volver al listado", portal_audit_events_path,
                class: "shrink-0 rounded-full border border-sarah-border bg-white px-4 py-2 text-sm font-medium text-sarah-ink shadow-sm hover:bg-sarah-surface" %>
  </div>

  <article class="mt-6 rounded-xl border border-sarah-border bg-sarah-surface/50 p-5 md:p-6">
    <pre class="whitespace-pre-wrap font-sans text-sm leading-relaxed text-sarah-ink"><%= @doc_content %></pre>
  </article>
</section>
