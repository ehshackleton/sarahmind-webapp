<%= form_with(model: [ :portal, patient ], class: "space-y-5") do |f| %>
  <% if patient.errors.any? %>
    <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-900">
      <p class="font-semibold">Revisa los campos del formulario:</p>
      <ul class="mt-2 list-disc pl-5">
        <% patient.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= f.label :full_name, "Nombre completo", class: "mb-1.5 block text-sm font-medium text-sarah-ink" %>
      <%= f.text_field :full_name, class: "w-full rounded-xl border border-sarah-border bg-sarah-surface px-3 py-2.5" %>
    </div>
    <div>
      <%= f.label :status, "Estado", class: "mb-1.5 block text-sm font-medium text-sarah-ink" %>
      <%= f.select :status,
                   Patient::STATUSES.map { |value| [value.capitalize, value] },
                   {},
                   class: "w-full rounded-xl border border-sarah-border bg-sarah-surface px-3 py-2.5" %>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= f.label :email, class: "mb-1.5 block text-sm font-medium text-sarah-ink" %>
      <%= f.email_field :email, class: "w-full rounded-xl border border-sarah-border bg-sarah-surface px-3 py-2.5" %>
    </div>
    <div>
      <%= f.label :phone, "Teléfono", class: "mb-1.5 block text-sm font-medium text-sarah-ink" %>
      <%= f.text_field :phone, class: "w-full rounded-xl border border-sarah-border bg-sarah-surface px-3 py-2.5" %>
    </div>
  </div>

  <div>
    <%= f.label :professional_id, "Profesional asignado", class: "mb-1.5 block text-sm font-medium text-sarah-ink" %>
    <%= f.collection_select :professional_id,
                            User.where(role: [ "professional", "system_admin" ]),
                            :id, :email,
                            { include_blank: "Sin asignar" },
                            class: "w-full rounded-xl border border-sarah-border bg-sarah-surface px-3 py-2.5" %>
  </div>

  <div>
    <%= f.label :summary, "Resumen de caso", class: "mb-1.5 block text-sm font-medium text-sarah-ink" %>
    <%= f.text_area :summary, rows: 4, class: "w-full rounded-xl border border-sarah-border bg-sarah-surface px-3 py-2.5" %>
  </div>

  <% if policy(patient).clinical_section? %>
    <div>
      <%= f.label :sensitive_notes, "Sección clínica protegida", class: "mb-1.5 block text-sm font-medium text-sarah-ink" %>
      <%= f.text_area :sensitive_notes, rows: 4, class: "w-full rounded-xl border border-sarah-border bg-sarah-surface px-3 py-2.5" %>
    </div>
  <% end %>

  <div>
    <%= f.label :documents, "Adjuntar documentos", class: "mb-1.5 block text-sm font-medium text-sarah-ink" %>
    <%= f.file_field :documents, multiple: true, direct_upload: false, class: "block w-full text-sm text-sarah-muted" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "rounded-full bg-sarah-calm px-5 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-sarah-calm/90" %>
    <%= link_to "Volver", portal_patients_path, class: "text-sm text-sarah-muted hover:underline" %>
  </div>
<% end %>
