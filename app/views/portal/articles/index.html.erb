<% content_for :title, "Artículos — Espacio clínico — SarahMind" %>

<section class="rounded-2xl border border-sarah-border bg-white/90 p-8 shadow-sm md:p-10">
  <header class="flex flex-wrap items-center justify-between gap-3 border-b border-sarah-border/80 pb-5">
    <div>
      <h1 class="font-serif text-2xl font-semibold text-sarah-ink md:text-3xl">Artículos</h1>
      <p class="mt-1 text-sm text-sarah-muted">Gestiona artículos para la sección pública de noticias y recursos.</p>
    </div>
    <%= link_to "Nuevo artículo", new_portal_article_path, class: "sarah-interactive-press rounded-full bg-sarah-calm px-4 py-2 text-sm font-medium text-white shadow-sm" %>
  </header>

  <% if @articles.any? %>
    <div class="mt-6 overflow-x-auto rounded-xl border border-sarah-border/70">
      <table class="min-w-full divide-y divide-sarah-border/70 text-sm">
        <thead class="bg-sarah-surface/70 text-left text-xs uppercase tracking-wide text-sarah-muted">
          <tr>
            <th class="px-4 py-3">Título</th>
            <th class="px-4 py-3">Estado</th>
            <th class="px-4 py-3">Autor</th>
            <th class="px-4 py-3">Publicado</th>
            <th class="px-4 py-3 text-right">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-sarah-border/60 bg-white">
          <% @articles.each do |article| %>
            <tr>
              <td class="px-4 py-3 font-medium text-sarah-ink"><%= article.title %></td>
              <td class="px-4 py-3 text-sarah-muted"><%= article.status.humanize %></td>
              <td class="px-4 py-3 text-sarah-muted"><%= article.author.email %></td>
              <td class="px-4 py-3 text-sarah-muted"><%= article.published_at&.strftime("%d/%m/%Y %H:%M") || "—" %></td>
              <td class="px-4 py-3 text-right">
                <div class="inline-flex items-center gap-2">
                  <%= link_to "Ver", portal_article_path(article), class: "text-sarah-calm hover:underline" %>
                  <%= link_to "Editar", edit_portal_article_path(article), class: "text-sarah-calm hover:underline" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="mt-6 text-sm text-sarah-muted">Aún no hay artículos creados.</p>
  <% end %>
</section>
