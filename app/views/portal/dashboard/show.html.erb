<% content_for :title, "Resumen — Espacio clínico — SarahMind" %>

<section class="rounded-2xl border border-sarah-border bg-white/90 p-8 shadow-sm md:p-10">
  <header class="border-b border-sarah-border/80 pb-6">
    <h1 class="font-serif text-2xl font-semibold text-sarah-ink md:text-3xl">Resumen del espacio clínico</h1>
    <p class="mt-2 max-w-2xl text-sm text-sarah-muted md:text-base">
      Hola, <span class="font-medium text-sarah-ink"><%= current_user.email %></span>
      (<%= t("user.roles.#{current_user.role}") %>).
      Los datos que ves respetan tu alcance profesional y las políticas de acceso del equipo.
    </p>
  </header>

  <% if @sessions_today.any? %>
    <section class="mt-6 rounded-xl border border-amber-200/90 bg-amber-50/90 p-4 md:p-5" aria-labelledby="hoy-agenda">
      <h2 id="hoy-agenda" class="font-serif text-lg font-semibold text-amber-950">Tu día en la agenda</h2>
      <p class="mt-1 text-sm text-amber-900/90">
        <%= @metrics[:sessions_today] %> <%= @metrics[:sessions_today] == 1 ? "sesión programada" : "sesiones programadas" %> para hoy (<%= l(Time.zone.today, format: :long) %>).
      </p>
      <ul class="mt-3 space-y-2 text-sm">
        <% @sessions_today.each do |s| %>
          <li class="flex flex-wrap items-baseline justify-between gap-2 rounded-lg bg-white/80 px-3 py-2 border border-amber-100">
            <span class="font-medium text-amber-950"><%= l(s.starts_at, format: :short) %> — <%= s.patient.full_name %></span>
            <%= link_to "Abrir", portal_therapy_session_path(s), class: "text-sm font-medium text-sarah-calm hover:underline" %>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <div class="mt-8 grid gap-8 lg:grid-cols-3">
    <div class="lg:col-span-2">
      <h2 class="text-xs font-semibold uppercase tracking-wide text-sarah-muted">Indicadores</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        <article class="rounded-xl border border-sarah-border bg-sarah-surface/80 p-4 shadow-sm">
          <p class="text-xs uppercase tracking-wide text-sarah-muted">Pacientes totales</p>
          <p class="mt-1 font-serif text-2xl font-semibold text-sarah-ink"><%= @metrics[:total_patients] %></p>
        </article>
        <article class="rounded-xl border border-sarah-border bg-sarah-surface/80 p-4 shadow-sm">
          <p class="text-xs uppercase tracking-wide text-sarah-muted">Pacientes activos</p>
          <p class="mt-1 font-serif text-2xl font-semibold text-sarah-ink"><%= @metrics[:active_patients] %></p>
        </article>
        <article class="rounded-xl border border-sarah-border bg-sarah-surface/80 p-4 shadow-sm">
          <p class="text-xs uppercase tracking-wide text-sarah-muted">Nuevos este mes</p>
          <p class="mt-1 font-serif text-2xl font-semibold text-sarah-ink"><%= @metrics[:new_patients_month] %></p>
        </article>
        <article class="rounded-xl border border-sarah-border bg-sarah-surface/80 p-4 shadow-sm">
          <p class="text-xs uppercase tracking-wide text-sarah-muted">Sesiones próximas</p>
          <p class="mt-1 font-serif text-2xl font-semibold text-sarah-calm-deep"><%= @metrics[:upcoming_sessions] %></p>
        </article>
        <article class="rounded-xl border border-sarah-border bg-sarah-surface/80 p-4 shadow-sm">
          <p class="text-xs uppercase tracking-wide text-sarah-muted">Sesiones hoy</p>
          <p class="mt-1 font-serif text-2xl font-semibold text-sarah-ink"><%= @metrics[:sessions_today] %></p>
        </article>
        <article class="rounded-xl border border-sarah-border bg-sarah-surface/80 p-4 shadow-sm">
          <p class="text-xs uppercase tracking-wide text-sarah-muted">Notas internas</p>
          <p class="mt-1 font-serif text-2xl font-semibold text-sarah-ink"><%= @metrics[:clinical_notes] %></p>
        </article>
        <article class="rounded-xl border border-sarah-border bg-sarah-surface/80 p-4 shadow-sm">
          <p class="text-xs uppercase tracking-wide text-sarah-muted">Pacientes con documentos</p>
          <p class="mt-1 font-serif text-2xl font-semibold text-sarah-ink"><%= @metrics[:documents_attached] %></p>
        </article>
      </div>
    </div>

    <aside class="rounded-xl border border-sarah-border/90 bg-gradient-to-b from-sarah-calm/5 to-white p-5 shadow-sm">
      <h2 class="font-serif text-lg font-semibold text-sarah-ink">Próximas sesiones</h2>
      <p class="mt-1 text-xs text-sarah-muted">Programadas a partir de ahora.</p>
      <% if @upcoming_sessions.any? %>
        <ul class="mt-4 space-y-3 text-sm">
          <% @upcoming_sessions.each do |s| %>
            <li class="rounded-lg border border-sarah-border/60 bg-white/90 px-3 py-2.5">
              <p class="font-medium text-sarah-ink"><%= l(s.starts_at, format: :short) %></p>
              <p class="text-sarah-muted"><%= s.patient.full_name %></p>
              <p class="text-xs text-sarah-muted"><%= s.professional.email %></p>
              <%= link_to "Ver detalle", portal_therapy_session_path(s), class: "mt-1 inline-block text-xs font-medium text-sarah-calm hover:underline" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="mt-4 text-sm text-sarah-muted">No hay sesiones programadas en el horizonte visible.</p>
      <% end %>
      <%= link_to "Abrir agenda completa", portal_therapy_sessions_path,
                  class: "mt-5 inline-flex w-full items-center justify-center rounded-full bg-sarah-calm px-4 py-2.5 text-sm font-medium text-white shadow-sm transition hover:bg-sarah-calm-deep" %>
    </aside>
  </div>

  <div class="mt-10 flex flex-wrap gap-3 border-t border-sarah-border/70 pt-8">
    <%= link_to "Pacientes", portal_patients_path,
                class: "inline-flex items-center justify-center rounded-full border border-sarah-border bg-white px-5 py-2.5 text-sm font-medium text-sarah-ink shadow-sm transition hover:bg-sarah-surface" %>
    <% if current_user.role_system_admin? %>
      <%= link_to "Auditoría", portal_audit_events_path,
                  class: "inline-flex items-center justify-center rounded-full border border-sarah-border bg-white px-5 py-2.5 text-sm font-medium text-sarah-ink shadow-sm transition hover:bg-sarah-surface" %>
      <%= link_to "Roles", portal_users_path,
                  class: "inline-flex items-center justify-center rounded-full border border-sarah-border bg-white px-5 py-2.5 text-sm font-medium text-sarah-ink shadow-sm transition hover:bg-sarah-surface" %>
    <% end %>
  </div>
</section>
