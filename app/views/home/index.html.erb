<% content_for :title, "SarahMind" %>

<section class="sarah-animate-in relative overflow-hidden rounded-2xl border border-sarah-border bg-gradient-to-br from-white via-sarah-surface to-sarah-sand/40 p-8 shadow-md backdrop-blur-sm md:p-10">
  <div class="sarah-hero-blob pointer-events-none absolute -right-20 -top-20 h-56 w-56 rounded-full bg-sarah-calm/10 blur-3xl" aria-hidden="true"></div>
  <p class="text-sm font-medium uppercase tracking-wide text-sarah-forest">Bienvenida y bienvenido</p>
  <h1 class="mt-3 font-serif text-3xl font-semibold leading-tight text-sarah-ink md:text-4xl">
    Acompañamiento, orientación y herramientas para personas que han vivido abuso, maltrato o violencia.
  </h1>
  <p class="mt-4 max-w-2xl text-lg text-sarah-muted">
    Recursos claros y prácticos para víctimas, sobrevivientes y redes de apoyo, con acceso simple a cursos,
    contenidos y orientación.
  </p>
  <div class="mt-8 flex flex-wrap gap-3">
    <%= link_to "Solicitar orientación", contact_path, class: "sarah-interactive-press inline-flex items-center justify-center rounded-full bg-sarah-calm px-5 py-2.5 text-sm font-medium text-white shadow-sm duration-200 ease-out hover:bg-sarah-calm/90 focus:outline-none focus:ring-2 focus:ring-sarah-calm focus:ring-offset-2" %>
    <%= link_to "Ver cursos", courses_path, class: "sarah-interactive-press inline-flex items-center justify-center rounded-full border border-sarah-border bg-sarah-surface px-5 py-2.5 text-sm font-medium text-sarah-ink duration-200 ease-out hover:border-sarah-calm/40 hover:bg-white focus:outline-none focus:ring-2 focus:ring-sarah-calm focus:ring-offset-2" %>
    <%= link_to "Portal de usuario", (user_signed_in? ? portal_root_path : new_user_session_path), class: "sarah-interactive-press inline-flex items-center justify-center rounded-full border border-transparent px-5 py-2.5 text-sm font-medium text-sarah-accent underline-offset-4 duration-200 ease-out hover:underline" %>
  </div>
</section>

<section class="mt-8 rounded-2xl border border-amber-200/80 bg-amber-50/90 p-6 text-sarah-ink shadow-sm">
  <h2 class="font-semibold text-amber-900">Si estás en riesgo inmediato</h2>
  <p class="mt-2 text-sm leading-relaxed text-amber-950/90 md:text-base">
    Busca ayuda urgente o comunícate con los canales oficiales de tu país. En Chile puedes contactar, por ejemplo, el
    <span class="font-medium">Fono 1455</span> (orientación en violencia contra las mujeres).
  </p>
</section>

<section class="mt-8 grid gap-4 md:grid-cols-3">
  <article class="sarah-card-lift sarah-animate-in rounded-xl border border-sarah-border bg-white p-5 shadow-sm [animation-delay:60ms]">
    <h3 class="font-semibold text-sarah-ink">Aprende y avanza</h3>
    <p class="mt-2 text-sm text-sarah-muted">Cursos breves sobre autocuidado, regulación emocional y redes de apoyo.</p>
    <%= link_to "Ver catálogo", courses_path, class: "mt-3 inline-block text-sm font-medium text-sarah-calm hover:underline" %>
  </article>
  <article class="sarah-card-lift sarah-animate-in rounded-xl border border-sarah-border bg-white p-5 shadow-sm [animation-delay:120ms]">
    <h3 class="font-semibold text-sarah-ink">Tips y ejercicios</h3>
    <p class="mt-2 text-sm text-sarah-muted">Biblioteca práctica para apoyo inicial y continuidad entre sesiones.</p>
    <%= link_to "Explorar recursos", tips_path, class: "mt-3 inline-block text-sm font-medium text-sarah-calm hover:underline" %>
  </article>
  <article class="sarah-card-lift sarah-animate-in rounded-xl border border-sarah-border bg-white p-5 shadow-sm [animation-delay:180ms]">
    <h3 class="font-semibold text-sarah-ink">Noticias y recursos</h3>
    <p class="mt-2 text-sm text-sarah-muted">Actualización de estudios, leyes y canales institucionales confiables.</p>
    <%= link_to "Ver noticias", news_path, class: "mt-3 inline-block text-sm font-medium text-sarah-calm hover:underline" %>
  </article>
</section>
