<% content_for :title, "Iniciar sesión — SarahMind" %>

<section class="mx-auto flex min-h-[65vh] w-full max-w-5xl items-center justify-center">
  <div class="w-full max-w-lg rounded-2xl border border-sarah-border bg-white/95 p-8 shadow-sm md:p-10">
    <div class="text-center">
      <p class="text-xs font-semibold uppercase tracking-wide text-sarah-calm">Portal privado</p>
      <h1 class="mt-2 font-serif text-3xl font-semibold text-sarah-ink">Iniciar sesión</h1>
      <p class="mt-2 text-sm text-sarah-muted">Accede a tu espacio personal de SarahMind.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-8 space-y-8" }) do |f| %>
      <div>
        <%= f.label :email, class: "mb-1.5 block text-sm font-medium text-sarah-ink" %>
        <%= f.email_field :email,
                          autofocus: true,
                          autocomplete: "email",
                          class: "w-full rounded-xl border border-sarah-border bg-sarah-surface px-3 py-2.5 text-sarah-ink outline-none transition focus:border-sarah-calm focus:ring-2 focus:ring-sarah-calm/20" %>
      </div>

      <div class="pt-1">
        <%= f.label :password, class: "mb-1.5 block text-sm font-medium text-sarah-ink" %>
        <%= f.password_field :password,
                             autocomplete: "current-password",
                             class: "w-full rounded-xl border border-sarah-border bg-sarah-surface px-3 py-2.5 text-sarah-ink outline-none transition focus:border-sarah-calm focus:ring-2 focus:ring-sarah-calm/20" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="block pt-1 text-sm text-sarah-muted">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-sarah-border text-sarah-calm focus:ring-sarah-calm/30" %>
          <span class="ml-2">Recordarme</span>
        </label>
      <% end %>

      <%= f.submit "Iniciar sesión",
                   class: "mt-2 block w-full rounded-full bg-sarah-calm px-5 py-2.5 text-sm font-medium text-white shadow-sm transition hover:bg-sarah-calm/90 focus:outline-none focus:ring-2 focus:ring-sarah-calm focus:ring-offset-2" %>
    <% end %>

    <div class="mt-6 border-t border-sarah-border pt-4 text-center text-sm">
      <%= link_to "¿Olvidaste tu contraseña?", new_password_path(resource_name), class: "text-sarah-calm hover:underline" %>
    </div>
  </div>
</section>
